{
    "name": "riteshdavv/drupal-recipe-validator",
    "description": "Standalone CLI tool to validate Drupal Recipe YAML files against the official schema — three-stage pipeline: syntax, schema conformance, and machine name validation.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Ritesh Kumar Singh",
            "email": "ritesh.davv@gmail.com",
            "homepage": "https://riteshsingh.vercel.app"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/yaml": "^7.0",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "DrupalRecipeValidator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DrupalRecipeValidator\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/validate-recipe"
    ],
    "scripts": {
        "test": "phpunit --testdox",
        "validate": "bin/validate-recipe"
    },
    "config": {
        "optimize-autoloader": true
    }
}
